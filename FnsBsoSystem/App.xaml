<Application x:Class="FnsBsoSystem.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            StartupUri="Window/AuthWindow.xaml">
    <Application.Resources>
        <!-- ЦВЕТОВАЯ ПАЛИТРА ФНС -->
        <SolidColorBrush x:Key="ColorPrimary" Color="#004D8C"/>
        <!-- Темно-синий -->
        <SolidColorBrush x:Key="ColorSecondary" Color="#EBF5FB"/>
        <!-- Светло-голубой -->
        <SolidColorBrush x:Key="ColorDanger" Color="#D32F2F"/>
        <!-- Красный -->
        <SolidColorBrush x:Key="ColorSuccess" Color="#2E7D32"/>
        <!-- Зеленый -->
        <SolidColorBrush x:Key="ColorBg" Color="#F4F7F9"/>
        <!-- Серый фон -->
        <SolidColorBrush x:Key="ColorText" Color="#333333"/>

        <!-- СТИЛЬ КНОПОК -->
        <Style TargetType="Button" x:Key="BtnPrimary">
            <Setter Property="Background" Value="{StaticResource ColorPrimary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.9"/>
                                <Setter Property="Background" Value="#FF4890CF"></Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>

            <!--<Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FF28FF00"></Setter>
                </Trigger>
            </Style.Triggers>-->
        </Style>

        <Style TargetType="Button" x:Key="BtnDanger" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="{StaticResource ColorDanger}"/>
        </Style>

        <Style TargetType="Button" x:Key="BtnSuccess" BasedOn="{StaticResource BtnPrimary}">
            <Setter Property="Background" Value="{StaticResource ColorSuccess}"/>
        </Style>

        <!-- СТИЛЬ TEXTBOX -->
        <Style TargetType="TextBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
        </Style>

        <!-- СТИЛЬ COMBOBOX -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>

        <!-- СТИЛЬ ТАБЛИЦЫ (DATAGRID) -->
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="White"/>
            <Setter Property="RowHeaderWidth" Value="0"/>
            <Setter Property="AutoGenerateColumns" Value="False"/>
            <Setter Property="CanUserAddRows" Value="False"/>
            <Setter Property="GridLinesVisibility" Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="#EEE"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="RowHeight" Value="40"/>
            <Setter Property="HeadersVisibility" Value="Column"/>
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="{StaticResource ColorPrimary}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Padding" Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
        </Style>
    </Application.Resources>
</Application>
