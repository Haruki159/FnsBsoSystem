<Page x:Class="FnsBsoSystem.Page.StockPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Склад" Background="White">

    <Page.Resources>
        <!-- ЦВЕТА -->
        <Color x:Key="ColorPrimary">#009CDF</Color>
        <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>

        <!-- СТИЛЬ ПОИСКА (Закругленный) -->
        <Style x:Key="SearchBoxStyle" TargetType="TextBox">
            <Setter Property="Height" Value="40"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" CornerRadius="20" BorderBrush="#E0E0E0" BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="🔍" Margin="10,0,0,0" VerticalAlignment="Center" Opacity="0.5"/>
                                <ScrollViewer x:Name="PART_ContentHost" Grid.Column="1" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- СТИЛЬ КНОПОК ИНСТРУМЕНТОВ -->
        <Style x:Key="ToolBtnStyle" TargetType="Button">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#555"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#EEE"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="10">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="{StaticResource BrushPrimary}"/>
                                <Setter Property="Foreground" Value="White"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BrushPrimary}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- СТИЛЬ ДЛЯ DATA GRID (Как на странице Истории) -->
        <Style x:Key="HeaderStyle" TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridColumnHeader">
                        <Border Background="{StaticResource BrushPrimary}" BorderThickness="0,0,1,0" BorderBrush="#33FFFFFF">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="RowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
            <Setter Property="BorderBrush" Value="#F0F0F0"/>
            <Setter Property="Height" Value="35"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#E1F5FE"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="30,20,30,30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- Заголовок-Карточка -->
            <RowDefinition Height="Auto"/>
            <!-- Панель инструментов -->
            <RowDefinition Height="*"/>
            <!-- Таблица -->
        </Grid.RowDefinitions>

        <!-- 1. ИНФОРМАЦИОННАЯ КАРТОЧКА (Вместо старой шапки формы) -->
        <Border Grid.Row="0" Background="White" CornerRadius="15" Margin="0,0,0,20">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Color="Black" Opacity="0.05" ShadowDepth="2"/>
            </Border.Effect>
            <Grid Margin="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="КНИГА УЧЕТА БЛАНКОВ" FontSize="22" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}"/>
                    <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Учреждение: " Foreground="#888"/>
                        <TextBlock Text="Межрайонная ИФНС №6" FontWeight="SemiBold" Foreground="#333" Margin="5,0,15,0"/>

                        <TextBlock Text="Отдел: " Foreground="#888"/>
                        <TextBlock Text="Административный" FontWeight="SemiBold" Foreground="#333" Margin="5,0,0,0"/>
                    </StackPanel>
                </StackPanel>

            </Grid>
        </Border>

        <!-- 2. ПАНЕЛЬ УПРАВЛЕНИЯ -->
        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <!-- Поиск -->
                <ColumnDefinition Width="*"/>
                <!-- Кнопки -->
            </Grid.ColumnDefinitions>

            <!-- Поиск -->
            <TextBox x:Name="TxtSearch" Style="{StaticResource SearchBoxStyle}" 
                     TextChanged="TxtSearch_TextChanged"/>
            <TextBlock IsHitTestVisible="False" Text="Поиск по серии, номеру..." VerticalAlignment="Center" Margin="40,0,0,0" Foreground="#AAA">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Text, ElementName=TxtSearch}" Value="">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- Кнопки действий -->
            <!-- Используем WrapPanel, чтобы кнопки переносились, если окно узкое -->
            <WrapPanel Grid.Column="1" HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Content="➕ Приход" Click="ActionAdd" Style="{StaticResource ToolBtnStyle}"/>
                <Button Content="📤 Выдача" Click="ActionIssue" Style="{StaticResource ToolBtnStyle}"/>
                <Button Content="🔥 Списание" Click="ActionSpoil" Style="{StaticResource ToolBtnStyle}"/>

                <Border Width="1" Height="25" Background="#DDD" Margin="5,0,15,0"/>

                <Button Content="✏ Ред." Click="ActionEdit" Style="{StaticResource ToolBtnStyle}"/>
                <Button Content="🗑 Удалить" Click="ActionDelete" Style="{StaticResource ToolBtnStyle}" Foreground="#C62828"/>

                <Border Width="1" Height="25" Background="#DDD" Margin="5,0,15,0"/>

                <Button Content="🔄" ToolTip="Обновить" Click="BtnRefresh_Click" Style="{StaticResource ToolBtnStyle}" Padding="10,8"/>
                <Button Content="Excel" Click="BtnExport_Click" Style="{StaticResource ToolBtnStyle}" Foreground="#2E7D32" FontWeight="Bold"/>
                <Button Content="Импорт" Click="BtnImport_Click" Style="{StaticResource ToolBtnStyle}" Foreground="#1565C0"/>
            </WrapPanel>
        </Grid>

        <!-- 3. ТАБЛИЦА (Карточный вид) -->
        <Border Grid.Row="2" Background="White" CornerRadius="15" BorderBrush="#E0E0E0" BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" Color="Black" Opacity="0.05" ShadowDepth="5"/>
            </Border.Effect>

            <Border CornerRadius="15" ClipToBounds="True">
                <DataGrid x:Name="GridStock" 
                          AutoGenerateColumns="False" 
                          IsReadOnly="True" 
                          HeadersVisibility="Column"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#F0F0F0"
                          BorderThickness="0"
                          Background="White"
                          ColumnHeaderStyle="{StaticResource HeaderStyle}"
                          RowStyle="{StaticResource RowStyle}">

                    <DataGrid.Resources>
                        <!-- Стиль ячейки по центру -->
                        <Style TargetType="DataGridCell">
                            <Setter Property="TextBlock.TextAlignment" Value="Center"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        </Style>
                    </DataGrid.Resources>

                    <DataGrid.Columns>
                        <!-- ДАТА (Объединена визуально заголовками, но данные те же) -->
                        <DataGridTextColumn Header="День" Binding="{Binding Day}" Width="50" Foreground="#777"/>
                        <DataGridTextColumn Header="Мес" Binding="{Binding Month}" Width="50" Foreground="#777"/>
                        <DataGridTextColumn Header="Год" Binding="{Binding Year}" Width="60" Foreground="#777"/>

                        <!-- Контрагент -->
                        <DataGridTextColumn Header="От кого / Кому" Binding="{Binding PersonName}" Width="200">
                            <DataGridTextColumn.ElementStyle>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Padding" Value="10,0"/>
                                    <Setter Property="TextAlignment" Value="Left"/>
                                    <Setter Property="VerticalAlignment" Value="Center"/>
                                </Style>
                            </DataGridTextColumn.ElementStyle>
                        </DataGridTextColumn>

                        <!-- Документ -->
                        <DataGridTextColumn Header="Основание" Binding="{Binding DocName}" Width="150"/>

                        <!-- ПРИХОД (Зеленоватый оттенок) -->
                        <DataGridTextColumn Header="Приход (шт)" Binding="{Binding InQty}" Width="90" FontWeight="Bold" Foreground="#2E7D32"/>
                        <DataGridTextColumn Header="Серия / Номер" Binding="{Binding InSeries}" Width="110" Foreground="#2E7D32"/>

                        <!-- РАСХОД (Красноватый оттенок) -->
                        <DataGridTextColumn Header="Расход (шт)" Binding="{Binding OutQty}" Width="90" FontWeight="Bold" Foreground="#C62828"/>
                        <DataGridTextColumn Header="Серия / Номер" Binding="{Binding OutSeries}" Width="110" Foreground="#C62828"/>

                        <!-- Остаток (Синий) -->
                        <DataGridTextColumn Header="Остаток (шт)" Binding="{Binding RemQty}" Width="90" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}"/>
                        <DataGridTextColumn Header="Серия / Номер" Binding="{Binding RemSeries}" Width="*" Foreground="{StaticResource BrushPrimary}"/>
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Border>
    </Grid>
</Page>