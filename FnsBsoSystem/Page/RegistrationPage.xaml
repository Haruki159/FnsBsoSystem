<Page x:Class="FnsBsoSystem.Page.RegistrationPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FnsBsoSystem.Page"
      mc:Ignorable="d" 
      d:DesignHeight="800" d:DesignWidth="1200"
      Title="Регистрация пользователя" Background="White">

    <!-- Локальные стили для красоты -->
    <Page.Resources>
        <!-- ОСНОВНЫЕ ЦВЕТА -->
        <Color x:Key="ColorPrimary">#009CDF</Color>
        <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>
        <SolidColorBrush x:Key="BrushText" Color="#444"/>
        <SolidColorBrush x:Key="BrushLabel" Color="#888"/>

        <!-- СТИЛЬ ЗАГОЛОВКОВ ПОЛЕЙ (Label) -->
        <Style x:Key="LabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource BrushLabel}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="10,0,0,6"/>
        </Style>

        <!-- СТИЛЬ ОБЕРТКИ ПОЛЕЙ ВВОДА (Скругленные плашки) -->
        <Style x:Key="InputWrapper" TargetType="Border">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#F0F2F5"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="#B3E5FC"/>
                    <!-- Подсветка при наведении -->
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- СТИЛЬ TEXTBOX (Внутри обертки) -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>

        <!-- СТИЛЬ COMBOBOX -->
        <Style TargetType="ComboBox">
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#333"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Border CornerRadius="20" Background="#F0F2F5" BorderThickness="0">
                            <Grid>
                                <ToggleButton Focusable="false" IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}" ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate>
                                            <Border Background="Transparent"/>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                                <ContentPresenter Name="ContentSite" IsHitTestVisible="False"  Content="{TemplateBinding SelectionBoxItem}" ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}" ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" Margin="15,0,30,0" VerticalAlignment="Center" HorizontalAlignment="Left" />
                                <Path Data="M0,0 L10,0 L5,5 Z" Fill="#999" HorizontalAlignment="Right" Margin="0,0,15,0" VerticalAlignment="Center" IsHitTestVisible="False"/>
                                <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}" AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                                    <Grid Name="DropDown" SnapsToDevicePixels="True" MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                        <Border x:Name="DropDownBorder" Background="White" BorderThickness="1" BorderBrush="#DDD" CornerRadius="10" Margin="0,5,0,0">
                                            <ScrollViewer Margin="4,6,4,6" SnapsToDevicePixels="True">
                                                <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained" />
                                            </ScrollViewer>
                                            <Border.Effect>
                                                <DropShadowEffect BlurRadius="10" Opacity="0.1"/>
                                            </Border.Effect>
                                        </Border>
                                    </Grid>
                                </Popup>
                            </Grid>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- СТИЛЬ ГЛАВНОЙ КНОПКИ (Pill) -->
        <Style x:Key="BtnSave" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="25" Background="{StaticResource BrushPrimary}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Page.Resources>

    <Grid Margin="40,20,40,40">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 1. ЗАГОЛОВОК СТРАНИЦЫ -->
        <StackPanel Grid.Row="0" Margin="0,0,0,30">
            <TextBlock Text="НОВЫЙ ПОЛЬЗОВАТЕЛЬ" FontSize="28" FontWeight="Bold" Foreground="#333"/>
            <TextBlock Text="Заполните анкету для создания учетной записи сотрудника" FontSize="14" Foreground="#888" Margin="2,5,0,0"/>
            <Border Width="50" Height="4" Background="{StaticResource BrushPrimary}" HorizontalAlignment="Left" CornerRadius="2" Margin="0,15,0,0"/>
        </StackPanel>

        <!-- 2. ОСНОВНАЯ КАРТОЧКА ФОРМЫ -->
        <Border Grid.Row="1" Background="White" CornerRadius="20" HorizontalAlignment="Stretch" VerticalAlignment="Top" MaxWidth="1100">
            <Border.Effect>
                <DropShadowEffect Color="Black" BlurRadius="30" ShadowDepth="5" Opacity="0.05"/>
            </Border.Effect>

            <Grid Margin="40">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*"/>
                    <!-- Личные данные -->
                    <ColumnDefinition Width="60"/>
                    <!-- Отступ -->
                    <ColumnDefinition Width="1"/>
                    <!-- Линия -->
                    <ColumnDefinition Width="60"/>
                    <!-- Отступ -->
                    <ColumnDefinition Width="2*"/>
                    <!-- Аккаунт -->
                </Grid.ColumnDefinitions>

                <!-- ЛЕВАЯ КОЛОНКА: ДАННЫЕ СОТРУДНИКА -->
                <StackPanel Grid.Column="0">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                        <Border Background="#E1F5FE" Width="30" Height="30" CornerRadius="10" Margin="0,0,10,0">
                            <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource BrushPrimary}" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Личные данные" FontSize="18" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- ФИО -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Фамилия" Style="{StaticResource LabelStyle}"/>
                            <Border Style="{StaticResource InputWrapper}">
                                <TextBox x:Name="TxtLast"/>
                            </Border>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Имя" Style="{StaticResource LabelStyle}"/>
                            <Border Style="{StaticResource InputWrapper}">
                                <TextBox x:Name="TxtFirst"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <TextBlock Text="Отчество" Style="{StaticResource LabelStyle}"/>
                    <Border Style="{StaticResource InputWrapper}">
                        <TextBox x:Name="TxtMiddle"/>
                    </Border>

                    <!-- Служебные данные -->
                    <TextBlock Text="Отдел / Подразделение" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="ComboDept" DisplayMemberPath="DeptName" SelectedValuePath="Id" Margin="0,0,0,20"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Должность" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="ComboPos" DisplayMemberPath="PosName" SelectedValuePath="Id" Margin="0,0,0,20"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Классный чин" Style="{StaticResource LabelStyle}"/>
                            <ComboBox x:Name="ComboRank" DisplayMemberPath="RankName" SelectedValuePath="Id" Margin="0,0,0,20"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>

                <!-- РАЗДЕЛИТЕЛЬНАЯ ЛИНИЯ -->
                <Border Grid.Column="2" Background="#EEEEEE"/>

                <!-- ПРАВАЯ КОЛОНКА: АККАУНТ -->
                <StackPanel Grid.Column="4">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,25">
                        <Border Background="#E1F5FE" Width="30" Height="30" CornerRadius="10" Margin="0,0,10,0">
                            <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource BrushPrimary}" FontWeight="Bold"/>
                        </Border>
                        <TextBlock Text="Доступ в систему" FontSize="18" FontWeight="Bold" Foreground="#333" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Карточка с данными входа -->
                    <Border Background="#FAFAFA" CornerRadius="15" Padding="20" Margin="0,0,0,25" BorderBrush="#EEE" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Логин" Style="{StaticResource LabelStyle}"/>
                            <Border Style="{StaticResource InputWrapper}" Background="White" BorderBrush="#E0E0E0">
                                <TextBox x:Name="TxtLogin" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}"/>
                            </Border>

                            <TextBlock Text="Пароль" Style="{StaticResource LabelStyle}"/>
                            <Border Style="{StaticResource InputWrapper}" Background="White" BorderBrush="#E0E0E0" Margin="0">
                                <TextBox x:Name="TxtPass"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Роль -->
                    <TextBlock Text="Роль пользователя" Style="{StaticResource LabelStyle}"/>
                    <ComboBox x:Name="ComboRole" Margin="0,0,0,40">
                        <ComboBoxItem Content="Admin"/>
                        <ComboBoxItem Content="Storekeeper"/>
                        <ComboBoxItem Content="Viewer" IsSelected="True"/>
                    </ComboBox>

                    <!-- КНОПКА СОХРАНЕНИЯ -->
                    <Button Content="Зарегистрировать сотрудника" 
                            Click="BtnReg_Click"
                            Style="{StaticResource BtnSave}" 
                            Height="50"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Page>
