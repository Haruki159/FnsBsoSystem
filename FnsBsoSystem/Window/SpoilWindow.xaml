<Window x:Class="FnsBsoSystem.SpoilWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FnsBsoSystem"
        mc:Ignorable="d"
         WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- ЦВЕТА (Красный акцент для опасного действия) -->
        <Color x:Key="ColorDanger">#E53935</Color>
        <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}"/>
        <SolidColorBrush x:Key="BrushLabel" Color="#888"/>

        <!-- СТИЛЬ ЗАГОЛОВКОВ ПОЛЕЙ -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{StaticResource BrushLabel}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="10,0,0,6"/>
        </Style>

        <!-- СТИЛЬ ОБЕРТКИ (КАПСУЛЫ) -->
        <Style TargetType="Border" x:Key="InputWrapper">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#F0F2F5"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- СТИЛЬ КНОПКИ (Красная) -->
        <Style TargetType="Button" x:Key="BtnDanger">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="25" Background="{StaticResource BrushDanger}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- КАРТОЧКА ОКНА -->
    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="*"/>
                <!-- Поля -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопка -->
            </Grid.RowDefinitions>

            <!-- 1. ЗАГОЛОВОК -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <StackPanel>
                    <!-- Красный заголовок -->
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="⚠ " Foreground="{StaticResource BrushDanger}" FontSize="18"/>
                        <TextBlock Text="СПИСАНИЕ" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushDanger}"/>
                    </StackPanel>
                    <TextBlock Text="Акт об уничтожении документа" FontSize="12" Foreground="#999"/>
                </StackPanel>

                <!-- Кнопка закрытия -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Click="BtnClose_Click" Cursor="Hand"
                        Background="Transparent" BorderThickness="0">
                    <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="#BBB" StrokeThickness="2"/>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Width="30" Height="30">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 2. ПОЛЯ ВВОДА -->
            <StackPanel Grid.Row="1">

                <!-- Номер бланка -->
                <TextBlock Text="Номер испорченного бланка" Style="{StaticResource LabelStyle}"/>
                <Border Style="{StaticResource InputWrapper}">
                    <!-- TxtNum сохранен -->
                    <TextBox x:Name="TxtNum"
                             Background="Transparent" BorderThickness="0"
                             VerticalContentAlignment="Center" Padding="15,0"
                             FontSize="14" FontWeight="Bold"/>
                </Border>

                <!-- Причина -->
                <TextBlock Text="Причина списания" Style="{StaticResource LabelStyle}"/>
                <Border Style="{StaticResource InputWrapper}">
                    <ComboBox x:Name="ComboReason"
                              Background="Transparent" BorderThickness="0"
                              VerticalContentAlignment="Center" Padding="10,0" Height="42">
                        <!-- Элементы сохранены -->
                        <ComboBoxItem Content="Технический брак" IsSelected="True"/>
                        <ComboBoxItem Content="Ошибка заполнения"/>
                        <ComboBoxItem Content="Утеря"/>
                    </ComboBox>
                </Border>

                <!-- Предупреждение -->
                <Border Background="#FFEBEE" CornerRadius="10" Padding="15" Margin="0,10,0,0">
                    <TextBlock Text="Внимание! Данное действие необратимо. Бланк будет помечен как испорченный и удален из активного учета."
                               FontSize="11" Foreground="#C62828" TextWrapping="Wrap"/>
                </Border>
            </StackPanel>

            <!-- 3. КНОПКА ПОДТВЕРДИТЬ -->
            <Button Grid.Row="2" Content="УНИЧТОЖИТЬ БЛАНК" 
                    Click="Save"
                    Style="{StaticResource BtnDanger}" Height="50" Margin="0,20,0,0"/>
        </Grid>
    </Border>
</Window>
