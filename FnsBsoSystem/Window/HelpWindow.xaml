<Window x:Class="FnsBsoSystem.Window.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FnsBsoSystem.Window"
        mc:Ignorable="d"
        Title="Справка и руководство" Height="600" Width="850"
        WindowStartupLocation="CenterScreen" ResizeMode="CanResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- ЦВЕТА -->
        <Color x:Key="ColorPrimary">#009CDF</Color>
        <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>
    </Window.Resources>

    <!-- ОСНОВНАЯ КАРТОЧКА ОКНА -->
    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Шапка -->
                <RowDefinition Height="*"/>
                <!-- Контент -->
            </Grid.RowDefinitions>

            <!-- 1. ШАПКА -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="СПРАВОЧНАЯ ИНФОРМАЦИЯ" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}"/>
                    <TextBlock Text="Руководство пользователя и инструкции" FontSize="12" Foreground="#999"/>
                </StackPanel>

                <!-- Кнопка закрытия -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Click="BtnClose_Click" Cursor="Hand"
                        Background="Transparent" BorderThickness="0">
                    <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="#CCC" StrokeThickness="2"/>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Width="30" Height="30">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 2. КОНТЕНТ (FlowDocumentReader) -->
            <Border Grid.Row="1" BorderBrush="#EEE" BorderThickness="1" CornerRadius="10">
                <FlowDocumentReader Name="MyDocumentDisplay" 
                                    ViewingMode="Scroll"
                                    BorderThickness="0"
                                    Background="White"/>
            </Border>
        </Grid>
    </Border>
</Window>
