<Window x:Class="FnsBsoSystem.EditInventoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FnsBsoSystem"
        mc:Ignorable="d"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- ТЕ ЖЕ РЕСУРСЫ (Стили), ЧТО И РАНЬШЕ -->
        <Color x:Key="ColorPrimary">#009CDF</Color>
        <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>
        <SolidColorBrush x:Key="BrushLabel" Color="#888"/>

        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{StaticResource BrushLabel}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="10,0,0,6"/>
        </Style>

        <Style TargetType="Border" x:Key="InputWrapper">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#F0F2F5"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="15,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Foreground" Value="#333"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="42"/>
        </Style>

        <Style TargetType="DatePicker">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="10,0"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Background" Value="Transparent"/>
        </Style>

        <Style TargetType="Button" x:Key="BtnSave">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="25" Background="{StaticResource BrushPrimary}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 1. ШАПКА -->
            <Grid Grid.Row="0" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="РЕДАКТИРОВАНИЕ" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}"/>
                    <TextBlock Text="Карточка учета БСО (ф. 0504045)" FontSize="12" Foreground="#999"/>
                </StackPanel>
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" Click="BtnClose_Click" Cursor="Hand" Background="Transparent" BorderThickness="0">
                    <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="#CCC" StrokeThickness="2"/>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Width="30" Height="30">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 2. КОНТЕНТ -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Hidden">
                <StackPanel>

                    <!-- БЛОК 1: Документ и Дата -->
                    <TextBlock Text="1. Основание операции" FontWeight="Bold" Foreground="#333" Margin="0,0,0,10"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- Дата -->
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Дата" Style="{StaticResource LabelStyle}"/>
                            <Border Style="{StaticResource InputWrapper}">
                                <DatePicker Name="PickerDate"/>
                            </Border>
                        </StackPanel>

                        <!-- Статус (Определяет колонку Приход/Расход) -->
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Тип (Статус)" Style="{StaticResource LabelStyle}"/>
                            <Border Style="{StaticResource InputWrapper}">
                                <ComboBox Name="ComboStatus" DisplayMemberPath="StatusName" SelectedValuePath="Id"/>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- БЛОК 2: Сотрудник -->
                    <TextBlock Text="2. Ответственное лицо" FontWeight="Bold" Foreground="#333" Margin="0,10,0,10"/>

                    <TextBlock Text="МОЛ (От кого / Кому)" Style="{StaticResource LabelStyle}"/>
                    <Border Style="{StaticResource InputWrapper}">
                        <ComboBox Name="ComboEmp" DisplayMemberPath="FullName" SelectedValuePath="Id"/>
                    </Border>

                    <!-- БЛОК 3: Бланки -->
                    <TextBlock Text="3. Бланки" FontWeight="Bold" Foreground="#333" Margin="0,10,0,10"/>

                    <TextBlock Text="Серия" Style="{StaticResource LabelStyle}"/>
                    <Border Style="{StaticResource InputWrapper}">
                        <TextBox Name="TxtSeries"/>
                    </Border>

                    <TextBlock Text="Диапазон номеров (Начало — Конец)" Style="{StaticResource LabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource InputWrapper}">
                            <TextBox Name="TxtStart" TextChanged="TxtStart_TextChanged" HorizontalContentAlignment="Center"/>
                        </Border>

                        <TextBlock Grid.Column="1" Text="—" VerticalAlignment="Top" HorizontalAlignment="Center" Margin="0,10,0,0" Foreground="#AAA" FontWeight="Bold"/>

                        <Border Grid.Column="2" Style="{StaticResource InputWrapper}">
                            <TextBox Name="TxtEnd" HorizontalContentAlignment="Center"/>
                        </Border>
                    </Grid>

                    <TextBlock Text="Количество (шт)" Style="{StaticResource LabelStyle}"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Style="{StaticResource InputWrapper}" Background="#E3F2FD">
                            <TextBox Name="TxtQty" TextChanged="TxtQty_TextChanged" 
                                     FontWeight="Bold" Foreground="{StaticResource BrushPrimary}" HorizontalContentAlignment="Center"/>
                        </Border>

                        <TextBlock Grid.Column="1" Text="← Измените количество для авторасчета." 
                                   VerticalAlignment="Center" Margin="15,0,0,15" Foreground="#888" FontSize="11"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>

            <!-- 3. КНОПКА -->
            <Button Grid.Row="2" Content="Сохранить изменения" 
                    Click="Save_Click"
                    Style="{StaticResource BtnSave}" Height="50" Margin="0,10,0,0"/>
        </Grid>
    </Border>
</Window>

