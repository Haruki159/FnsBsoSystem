<Window x:Class="FnsBsoSystem.IssueWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        

    Title="Выдача бланков" Height="500" Width="400" 
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- ЦВЕТА -->
        <Color x:Key="ColorPrimary">#009CDF</Color>
        <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>
        <SolidColorBrush x:Key="BrushLabel" Color="#888"/>

        <!-- СТИЛЬ ЗАГОЛОВКОВ ПОЛЕЙ -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{StaticResource BrushLabel}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="10,0,0,6"/>
        </Style>

        <!-- СТИЛЬ ОБЕРТКИ (КАПСУЛЫ) -->
        <Style TargetType="Border" x:Key="InputWrapper">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#F0F2F5"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,20"/>
        </Style>

        <!-- СТИЛЬ КНОПКИ -->
        <Style TargetType="Button" x:Key="BtnPrimary">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="25" Background="{StaticResource BrushPrimary}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- КАРТОЧКА ОКНА -->
    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="*"/>
                <!-- Поля -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопка -->
            </Grid.RowDefinitions>

            <!-- 1. ЗАГОЛОВОК -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <StackPanel>
                    <TextBlock Text="ВЫДАЧА БЛАНКОВ" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}"/>
                    <TextBlock Text="Оформление передачи сотруднику" FontSize="12" Foreground="#999"/>
                </StackPanel>

                <!-- Кнопка закрытия -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Click="BtnClose_Click" Cursor="Hand"
                        Background="Transparent" BorderThickness="0">
                    <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="#BBB" StrokeThickness="2"/>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Width="30" Height="30">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 2. ПОЛЯ ВВОДА -->
            <StackPanel Grid.Row="1">

                <!-- Откуда -->
                <TextBlock Text="Источник (Пачка)" Style="{StaticResource LabelStyle}"/>
                <Border Style="{StaticResource InputWrapper}">
                    <ComboBox x:Name="ComboSource" 
                              DisplayMemberPath="FullDesc" SelectedValuePath="Id"
                              Background="Transparent" BorderThickness="0"
                              VerticalContentAlignment="Center" Padding="10,0" Height="42"/>
                </Border>

                <!-- Кому -->
                <TextBlock Text="Получатель (Сотрудник)" Style="{StaticResource LabelStyle}"/>
                <Border Style="{StaticResource InputWrapper}">
                    <ComboBox x:Name="ComboEmp" 
                              DisplayMemberPath="FullName" SelectedValuePath="Id"
                              Background="Transparent" BorderThickness="0"
                              VerticalContentAlignment="Center" Padding="10,0" Height="42"/>
                </Border>

                <!-- Количество -->
                <TextBlock Text="Количество" Style="{StaticResource LabelStyle}"/>
                <Border Style="{StaticResource InputWrapper}">
                    <TextBox x:Name="TxtQty"
                             Background="Transparent" BorderThickness="0"
                             VerticalContentAlignment="Center" Padding="15,0"
                             FontSize="14"/>
                </Border>
            </StackPanel>

            <!-- 3. КНОПКА СОХРАНИТЬ -->
            <Button Grid.Row="2" Content="Оформить выдачу" 
                    Click="Save"
                    Style="{StaticResource BtnPrimary}" Height="50" Margin="0,10,0,0"/>
        </Grid>
    </Border>
</Window>
