<Window x:Class="FnsBsoSystem.ReceiptWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- ЦВЕТА -->
        <Color x:Key="ColorPrimary">#009CDF</Color>
        <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>
        <SolidColorBrush x:Key="BrushLabel" Color="#888"/>

        <!-- СТИЛЬ ЗАГОЛОВКОВ ПОЛЕЙ -->
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{StaticResource BrushLabel}"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin" Value="10,0,0,6"/>
        </Style>

        <!-- СТИЛЬ ОБЕРТКИ (КАПСУЛЫ) -->
        <Style TargetType="Border" x:Key="InputWrapper">
            <Setter Property="CornerRadius" Value="20"/>
            <Setter Property="Background" Value="#F0F2F5"/>
            <Setter Property="Height" Value="42"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <!-- СТИЛЬ КНОПКИ -->
        <Style TargetType="Button" x:Key="BtnPrimary">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="25" Background="{StaticResource BrushPrimary}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- КАРТОЧКА ОКНА -->
    <Border Background="White" CornerRadius="20" Margin="10">
        <Border.Effect>
            <DropShadowEffect Color="Black" BlurRadius="20" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid Margin="30">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <!-- Заголовок -->
                <RowDefinition Height="*"/>
                <!-- Поля -->
                <RowDefinition Height="Auto"/>
                <!-- Кнопка -->
            </Grid.RowDefinitions>

            <!-- 1. ЗАГОЛОВОК -->
            <Grid Grid.Row="0" Margin="0,0,0,25">
                <StackPanel>
                    <TextBlock Text="ПОСТУПЛЕНИЕ" FontSize="18" FontWeight="Bold" Foreground="{StaticResource BrushPrimary}"/>
                    <TextBlock Text="Регистрация новой партии бланков" FontSize="12" Foreground="#999"/>
                </StackPanel>

                <!-- Кнопка закрытия -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                        Click="BtnClose_Click" Cursor="Hand"
                        Background="Transparent" BorderThickness="0">
                    <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="#BBB" StrokeThickness="2"/>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border Background="Transparent" Width="30" Height="30">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>

            <!-- 2. ПОЛЯ ВВОДА -->
            <StackPanel Grid.Row="1">

                <!-- Тип бланка -->
                <TextBlock Text="Тип документа" Style="{StaticResource LabelStyle}"/>
                <Border Style="{StaticResource InputWrapper}">
                    <!-- Name="ComboTypes" сохранен -->
                    <ComboBox Name="ComboTypes" 
                              DisplayMemberPath="TypeName" SelectedValuePath="Id"
                              Background="Transparent" BorderThickness="0"
                              VerticalContentAlignment="Center" Padding="10,0" Height="42"/>
                </Border>

                <!-- Серия -->
                <TextBlock Text="Серия" Style="{StaticResource LabelStyle}"/>
                <Border Style="{StaticResource InputWrapper}">
                    <!-- Name="TxtSeries" сохранен -->
                    <TextBox Name="TxtSeries"
                             Background="Transparent" BorderThickness="0"
                             VerticalContentAlignment="Center" Padding="15,0"
                             FontSize="14"/>
                </Border>

                <!-- Диапазон (Две колонки) -->
                <TextBlock Text="Диапазон номеров (Начало — Конец)" Style="{StaticResource LabelStyle}"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Начало -->
                    <Border Grid.Column="0" Style="{StaticResource InputWrapper}">
                        <!-- Name="TxtStart" сохранен -->
                        <TextBox Name="TxtStart"
                                 Background="Transparent" BorderThickness="0"
                                 VerticalContentAlignment="Center" Padding="15,0"
                                 FontSize="14" HorizontalContentAlignment="Center"/>
                    </Border>

                    <!-- Разделитель -->
                    <TextBlock Grid.Column="1" Text="—" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="#999" Margin="0,0,0,15" FontWeight="Bold"/>

                    <!-- Конец -->
                    <Border Grid.Column="2" Style="{StaticResource InputWrapper}">
                        <!-- Name="TxtEnd" сохранен -->
                        <TextBox Name="TxtEnd"
                                 Background="Transparent" BorderThickness="0"
                                 VerticalContentAlignment="Center" Padding="15,0"
                                 FontSize="14" HorizontalContentAlignment="Center"/>
                    </Border>
                </Grid>
            </StackPanel>

            <!-- 3. КНОПКА СОХРАНИТЬ -->
            <Button Grid.Row="2" Content="Зарегистрировать приход" 
                    Click="Save"
                    Style="{StaticResource BtnPrimary}" Height="50" Margin="0,15,0,0"/>
        </Grid>
    </Border>
</Window>