<Window x:Class="FnsBsoSystem.AuthWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:FnsBsoSystem"
        mc:Ignorable="d"
        Title="Вход в систему" Height="550" Width="400" 
        ResizeMode="NoResize" WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        MouseDown="Window_MouseDown">

    <Window.Resources>
        <!-- ЦВЕТА (Дублируем, чтобы окно работало автономно) -->
        <Color x:Key="ColorPrimary">#009CDF</Color>
        <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}"/>

        <!-- СТИЛЬ ДЛЯ КНОПКИ (Pill Shape) -->
        <Style x:Key="BtnAuthMain" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" CornerRadius="25" Background="{StaticResource BrushPrimary}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,12"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Opacity" Value="0.9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- СТИЛЬ ДЛЯ ТЕКСТОВЫХ ПОЛЕЙ (Обертка в Border) -->
        <Style x:Key="InputBorder" TargetType="Border">
            <Setter Property="CornerRadius" Value="15"/>
            <Setter Property="Background" Value="#F5F7FA"/>
            <Setter Property="Height" Value="45"/>
            <Setter Property="Margin" Value="0,5,0,20"/>
        </Style>

    </Window.Resources>

    <Grid Background="Transparent">
        <!-- 1. ОБЩИЙ ФОН (Синий градиент, как на главной) -->
        <Border CornerRadius="20" ClipToBounds="True">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#0080C0" Offset="0.0"/>
                    <GradientStop Color="#004070" Offset="0.9"/>
                </LinearGradientBrush>
            </Border.Background>

            <Grid>
                <!-- Декоративные элементы (Треугольник) -->
                <Path Data="M 200,0 L 400,0 L 400,550 L 50,550 Z" 
                      Fill="White" Opacity="0.05" Stretch="Fill"/>

                <Path Data="M -50,400 L 100,550 L -50,550 Z" 
                      Fill="#009CDF" Opacity="0.4"/>
            </Grid>
        </Border>

        <!-- 2. КНОПКА ЗАКРЫТИЯ (Крестик справа сверху) -->
        <Button HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,15,15,0"
                Click="BtnExit_Click" Cursor="Hand"
                Background="Transparent" BorderThickness="0">
            <Path Data="M0,0 L10,10 M10,0 L0,10" Stroke="White" StrokeThickness="2" Opacity="0.7"/>
            <Button.Style>
                <Style TargetType="Button">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="Button">
                                <Border Background="Transparent" Width="30" Height="30">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Button.Style>
        </Button>


        <!-- 3. ЦЕНТРАЛЬНАЯ КАРТОЧКА -->
        <Border Background="White" CornerRadius="20" Margin="40" VerticalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="30" Color="Black" Opacity="0.25" ShadowDepth="10"/>
            </Border.Effect>

            <StackPanel Margin="30">
                <!-- Заголовок -->
                <StackPanel Orientation="Vertical" HorizontalAlignment="Center" Margin="0,0,0,5">
                    <TextBlock Text="Автоматизация" FontWeight="Bold" FontSize="20" Foreground="#333"/>
                    <TextBlock Text="Учета бланков" FontWeight="Bold" FontSize="20" Foreground="#333" HorizontalAlignment="Center"/>
                </StackPanel>
                <TextBlock Text="Авторизация" HorizontalAlignment="Center" FontSize="14" Foreground="#777" Margin="0,0,0,30"/>

                <!-- Поле Логина -->
                <TextBlock Text="Логин" Foreground="#555" FontWeight="SemiBold" Margin="5,0,0,0"/>
                <Border Style="{StaticResource InputBorder}">
                    <TextBox x:Name="TxtLogin" 
                             Background="Transparent" BorderThickness="0" 
                             VerticalContentAlignment="Center" Padding="10,0"
                             FontSize="14" FontWeight="SemiBold" Foreground="#333"/>
                </Border>

                <!-- Поле Пароля -->
                <TextBlock Text="Пароль" Foreground="#555" FontWeight="SemiBold" Margin="5,0,0,0"/>
                <Border Style="{StaticResource InputBorder}">
                    <PasswordBox x:Name="TxtPass" 
                                 Background="Transparent" BorderThickness="0" 
                                 VerticalContentAlignment="Center" Padding="10,0"
                                 FontSize="14" FontWeight="SemiBold" Foreground="#333"/>
                </Border>

                <!-- Кнопка Войти -->
                <Button Content="ВОЙТИ В СИСТЕМУ" Click="BtnLogin_Click" 
                        Style="{StaticResource BtnAuthMain}" Height="50" Margin="0,10,0,15"/>

                <!-- Кнопка Выход (текстовая) -->
                <Button Content="Отмена" Click="BtnExit_Click" 
                        Foreground="#999" Background="Transparent" BorderThickness="0" 
                        Cursor="Hand" FontSize="12"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
